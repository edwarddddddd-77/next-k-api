# Railway 生产 — 最小配置
# 密钥勿提交 git

# Bitget 实盘（推荐）
BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_PASSPHRASE=

# 或 Binance
# BINANCE_API_KEY=
# BINANCE_API_SECRET=

VNPY_LIVE_EXCHANGE=bitget
MARKET_DATA_EXCHANGE=bitget

TG_BOT_TOKEN=
TG_CHAT_ID=

# 策略开关（每个 lane 一对；仍兼容 ORB_VNPY_* / MTFMOMO_VNPY_* 旧名）
STRATEGY_TRADING_ORB_ENABLED=1
STRATEGY_TRADING_ORB_LIVE=1
# STRATEGY_MTFMOMO_ENABLED=1
# STRATEGY_MTFMOMO_LIVE=1
# STRATEGY_KAMA_TREND_ENABLED=1
# STRATEGY_KAMA_TREND_LIVE=1
# STRATEGY_SQUEEZE_BREAKOUT_ENABLED=1
# STRATEGY_ANCHOR_DRIFT_ENABLED=1
# STRATEGY_ANCHOR_DRIFT_LIVE=0
# STRATEGY_SQUEEZE_BREAKOUT_LIVE=1

# 全局 vnpy 总开关（默认开，设 0 关闭所有策略引擎）
# VNPY_ENABLED=1

# 仅当与默认不同时才加
# STRATEGY_TRADING_ORB_SHADOW=1
# ORB_VNPY_EQUITY_USDT=50

# 临时导出 DATA_DIR 卷
# NEXT_K_EXPORT_VOLUME_ENABLED=1

