# Railway / 生产 — Trading ORB vnpy
# 在 Railway Variables 中逐项设置；密钥勿提交 git

DATA_DIR=/app/data
ORB_KLINE_CACHE_ROOT=/app/data/orb/kline

NEXT_K_EMBED_SCHEDULER=1
NEXT_K_EXPORT_VOLUME_ENABLED=1

BINANCE_API_KEY=
BINANCE_API_SECRET=
# BINANCE_SERVER=REAL
# BINANCE_KLINE_STREAM=True

# 实盘交易所：binance（默认）| bybit
# VNPY_LIVE_EXCHANGE=binance
# 行情源（默认同 VNPY_LIVE_EXCHANGE，可单独指定）
# MARKET_DATA_EXCHANGE=binance
# VNPY_MARKET_DATA_EXCHANGE=binance
# ORB_MARKET_DATA_EXCHANGE=binance
# BYBIT_API_KEY=
# BYBIT_API_SECRET=
# BYBIT_SERVER=REAL

TG_BOT_TOKEN=
TG_CHAT_ID=

# ═══════════════════════════════════════════════════════════════
# Trading ORB vnpy（启用）
# ═══════════════════════════════════════════════════════════════
ORB_VNPY_ENABLED=1
ORB_VNPY_AUTO_START=1
ORB_VNPY_LIVE_ENABLED=1
# ORB_VNPY_SHADOW=0

ORB_VNPY_OR_MINUTES=20
ORB_VNPY_VOL_THRESH=1.2
ORB_VNPY_STOP_OR_MULT=0.5
ORB_VNPY_TARGET_OR_MULT=0.75
ORB_VNPY_BREAKEVEN_OR_MULT=1.0
ORB_VNPY_ENTRY_START=10:00
ORB_VNPY_ENTRY_END=11:30
ORB_VNPY_EXIT_HOUR=15
ORB_VNPY_EXIT_MINUTE=50

ORB_VNPY_EQUITY_USDT=50
ORB_VNPY_RISK_PCT=0.01
ORB_VNPY_COMPOUND=1
ORB_VNPY_MAX_NOTIONAL_USDT=0
ORB_VNPY_MAX_OPEN_POSITIONS=7
ORB_VNPY_LIVE_LEVERAGE=5
ORB_VNPY_RTH_ONLY=1
ORB_VNPY_EOD_FLAT=1
ORB_ONE_TRADE_PER_SESSION=1

ORB_MARKET=us_equity
ORB_SESSION_TZ=America/New_York
ORB_SESSION_OPEN=09:30
ORB_SESSION_CLOSE=16:00
ORB_MACRO_FILTER=1

# 标的池默认 config/trading_orb/symbols.txt（pool7）
# ORB_VNPY_SYMBOLS=INTCUSDT,SOXLUSDT,HOODUSDT,CRCLUSDT,COINUSDT,SNDKUSDT,MSTRUSDT
