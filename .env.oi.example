# Next K API — Trading ORB + ICT 2022 vnpy 实盘（币安直连）
# 复制为 next-k-api/.env.oi

NEXT_K_EMBED_SCHEDULER=1

# ═══════════════════════════════════════════════════════════════
# Trading ORB（sam-bateman/trading-orb 规则 + vnpy + 币安）
# ═══════════════════════════════════════════════════════════════
ORB_VNPY_ENABLED=1
ORB_VNPY_AUTO_START=1
ORB_VNPY_LIVE_ENABLED=1
# 币安 API
BINANCE_API_KEY=
BINANCE_API_SECRET=
# BINANCE_SERVER=REAL
# BINANCE_KLINE_STREAM=True
# BINANCE_PROXY_HOST=
# BINANCE_PROXY_PORT=0

# 标的池 config/trading_orb/symbols.txt
# ORB_VNPY_SYMBOLS=INTCUSDT,SOXLUSDT,HOODUSDT

ORB_MARKET=us_equity
ORB_SESSION_TZ=America/New_York
ORB_SESSION_OPEN=09:30
ORB_SESSION_CLOSE=16:00
ORB_MACRO_FILTER=1

# trading-orb 核心参数（ORB_VNPY_* 与 ORB V2 扫描隔离）
ORB_VNPY_OR_MINUTES=20
ORB_VNPY_VOL_THRESH=1.2
ORB_VNPY_STOP_OR_MULT=0.5
ORB_VNPY_TARGET_OR_MULT=0.75
ORB_VNPY_BREAKEVEN_OR_MULT=1.0
ORB_VNPY_ENTRY_START=10:00
ORB_VNPY_ENTRY_END=11:30
ORB_VNPY_EXIT_HOUR=15
ORB_VNPY_EXIT_MINUTE=50

ORB_VNPY_EQUITY_USDT=98
ORB_VNPY_RISK_PCT=0.01
# 固定美元风险（>0 时覆盖 risk_pct）
# ORB_VNPY_RISK_PER_TRADE=400
ORB_VNPY_MAX_OPEN_POSITIONS=7
ORB_VNPY_LIVE_LEVERAGE=5
ORB_ONE_TRADE_PER_SESSION=1

# ORB_VNPY_SHADOW=1
# ORB_VNPY_IDLE_OUTSIDE_RTH=1

# ═══════════════════════════════════════════════════════════════
# ICT 2022（与 ORB 同引擎并行，共享币安 Gateway）
# ═══════════════════════════════════════════════════════════════
ICT_VNPY_ENABLED=1
ICT_VNPY_LIVE_ENABLED=1
ICT_VNPY_SYMBOLS=ETHUSDT
ICT_VNPY_HMM_FILTER=1
ICT_VNPY_LEVERAGE=2
ICT_VNPY_LIVE_LEVERAGE=2
ICT_VNPY_POSITION_PCT=1.0
ICT_VNPY_RR=1.5
ICT_VNPY_INIT_BAR_DAYS=3
ICT_VNPY_EQUITY_USDT=1000
# ICT_VNPY_SHADOW=1

# ═══════════════════════════════════════════════════════════════
# Aberration CTA（布林带突破，与 ORB/ICT 同引擎并行）
# ═══════════════════════════════════════════════════════════════
ABERRATION_VNPY_ENABLED=1
# 先 shadow 发信号不下单；确认后 ABERRATION_VNPY_SHADOW=0 且 LIVE=1
ABERRATION_VNPY_SHADOW=1
ABERRATION_VNPY_LIVE_ENABLED=0
# 标的池 config/aberration/symbols.txt（勿与 ORB/ICT 重叠）
# ABERRATION_VNPY_SYMBOLS=BTCUSDT,SOLUSDT,BNBUSDT
ABERRATION_VNPY_N_PERIOD=35
ABERRATION_VNPY_K_UP=2
ABERRATION_VNPY_K_DOWN=2
ABERRATION_VNPY_BAR_HOURS=1
ABERRATION_VNPY_EQUITY_USDT=500
ABERRATION_VNPY_POSITION_PCT=1.0
ABERRATION_VNPY_LEVERAGE=2
ABERRATION_VNPY_LIVE_LEVERAGE=2
ABERRATION_VNPY_INIT_BAR_DAYS=14

# ═══════════════════════════════════════════════════════════════
# 期货 Skew 中性策略（截面 OI + 费率 Skew → 配对信号）
# ═══════════════════════════════════════════════════════════════
# profile: aggressive（默认 25%×2x）| balanced（10%×1x 保守）
# SKEW_PROFILE=aggressive
# SKEW_PAIR_RISK_PCT=0.25
# SKEW_PAIR_LEVERAGE=2.0
# SKEW_MIN_SKEW_GAP=1.0
# SKEW_SUGGESTED_HOLD_HOURS=48
# SKEW_ENABLE_DARK_LONG=0
# SKEW_REGIME_BTC_DROP_PCT=5.0