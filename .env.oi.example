# 复制为 next-k-api/.env.oi（本地）或写入 Railway 环境变量
# 单服务：API 进程内嵌定时任务，无需再跑 scheduler_main.py

NEXT_K_EMBED_SCHEDULER=1
ZCT_VWAP_SIGNAL_SCHEDULER_ENABLED=1

# 触轨池双引擎：08:05 全市场主筛 + 每 4h 池内 24h 滚动回测清洗
# ZCT_TOUCH_POOL_CRON_HOUR=8
# ZCT_TOUCH_POOL_CRON_MINUTE=5
# 滚动清洗（12:05/16:05/20:05/00:05/04:05）：池内 24h 回测；触轨胜率<70% / PF<1.15 / 末段连亏>=3 则出池
# ZCT_TOUCH_POOL_ROLLING_ENABLED=1
# ZCT_TOUCH_POOL_ROLLING_MIN_WIN_RATE=0.70
# ZCT_TOUCH_POOL_ROLLING_MIN_PF=1.15
# ZCT_TOUCH_POOL_ROLLING_MAX_CONSEC_LOSSES=3
# ZCT_TOUCH_POOL_ROLLING_MIN_TOUCH_TRADES=5
# ZCT_TOUCH_POOL_ROLLING_DAYS=1
# ZCT_TOUCH_POOL_EMPTY_TG=1
# ZCT_PLAY03_TP_MODE=vwap
# ZCT_TOUCH_POOL_TAKER_BPS=4
# ZCT_TOUCH_POOL_SLIPPAGE_BPS=1.5

# 数据目录（Railway 挂载 Volume 时通常为 /data）
# DATA_DIR=/data

# 维护：清库 / 手动 Cron（生产建议设置）
# NEXT_K_MAINTENANCE_TOKEN=your-secret

# 可选
# S6_FUTURES_ALPHA_SCHEDULER_ENABLED=1
# OI_RADAR_REFRESH_COOLDOWN_SEC=120
# ZCT_VWAP_SCAN_INTERVAL_MINUTES=12
# ZCT_VWAP_RESOLVE_INTERVAL_MINUTES=5
