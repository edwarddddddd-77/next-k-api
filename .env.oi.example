# Next K API — 本地 / Railway 环境变量示例
# 复制为 next-k-api/.env.oi

NEXT_K_EMBED_SCHEDULER=1

# DATA_DIR=/data
# NEXT_K_EXPORT_VOLUME_ENABLED=1

# ORB 过滤（V2 推荐：宏观开）
# ORB_MACRO_FILTER=1

# ORB_SCAN_INTERVAL_MINUTES=5
# ORB_SCAN_CRON_SECOND=5

# ORB 每标 bot 初始本金（U）
# ORB_SYMBOL_BOT_EQUITY=1000

# ORB 2.0 扫描标的（默认 config/orb/v2/symbols.txt，8 标 Top8）
# ORB_V2_SYMBOLS=
# ORB_V2_SYMBOLS_FILE=  留空；默认 config/orb/v2/symbols.txt

# ORB 实盘 → Next-k-protocol（ORB_LIVE_ENABLED=1 时必须设 PROTOCOL_API_URL）
# ORB_LIVE_ENABLED=0
# PROTOCOL_API_URL=http://localhost:8001
# ORB_LIVE_LEVERAGE=5
# ORB_ENTRY_FILL=fvg_prox 时实盘自动发 LIMIT（近沿 FVG）；无需再设 stoplimit_gap
# ORB_LIVE_ENTRY_TYPE=stoplimit_gap
# ORB_LEVERAGE=5
# ORB_MARGIN_USDT=100

# --- ORB 2.0（ML Live Gate）---
# ORB_V2_ENABLED=1
# ORB_V2_SCHEDULER_ENABLED=1
# 实盘参数统一在 orb_live/（Gate + 模型），直接覆盖文件后 git 部署即可
# ORB_LIVE_BUNDLE_ROOT=  留空；默认 orb_live/
# ORB_V2_MONTHLY_TRAIN_ENABLED=0
# 关闭 ML p / BS / early-trap 过滤：=0 强制关；留空则读 live_gate.json ml_gate_enabled
# ORB_V2_GATE_ML=1
# ORB_ML_KLINE_REFRESH_ENABLED=1
# ORB_ML_KLINE_DAYS=180
# ORB_KLINE_CACHE_ROOT=data/orb/kline
# K 线拉取（国内需 VPN/代理）：HTTPS_PROXY=http://127.0.0.1:7890
# BINANCE_FAPI_BASE=https://fapi.binance.com
# BINANCE_FAPI_TIMEOUT_SEC=12
# ORB_V2_ROBOT_COUNT=8  # 共享池以 orb_live/live_gate.json robot_pool_size 为准；env 仅在 bound 模式生效
# 单 robot 本金(U)；8 台满员并发保证金 ≈ equity × 8.3（5x、1% 风险）。140U 账户目标峰值 ≤120U 时用 14
# ORB_V2_ROBOT_EQUITY=14
# 25 标扫描池 + 8 robot 共享（live_gate robot_reuse）；仅 symbols 数 == ROBOT_COUNT 时可 ORB_V2_ROBOT_BOUND=1
# ORB_V2_ROBOT_BOUND=0
