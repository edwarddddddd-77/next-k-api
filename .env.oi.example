# 复制为 next-k-api/.env.oi（本地）或写入 Railway 环境变量

# 单服务：API 进程内嵌定时任务，无需再跑 scheduler_main.py



NEXT_K_EMBED_SCHEDULER=1

ZCT_VWAP_SIGNAL_SCHEDULER_ENABLED=1



# 触轨池默认（与 touch_pool_config.py 一致；每 4h 全宇宙 6h walk + 全表重写）

ZCT_TOUCH_POOL_CRON_HOURS=0,4,8,12,16,20

ZCT_TOUCH_POOL_CRON_MINUTE=7

ZCT_TOUCH_POOL_WALK_HOURS=6

ZCT_TOUCH_POOL_MIN_TOTAL_TRADES=10

ZCT_TOUCH_POOL_MIN_WIN_LOSS_ABS=10

ZCT_TOUCH_POOL_MIN_TOUCH_TRADES=10

ZCT_TOUCH_POOL_MIN_TOUCH_WIN_RATE=0.82

ZCT_TOUCH_POOL_MIN_PF=1.30

ZCT_TOUCH_POOL_MAX_CONSEC_LOSSES=1

ZCT_TOUCH_POOL_MIN_T4_WIN_RATE=0

ZCT_TOUCH_POOL_BUCKET_HOURS=6

ZCT_TOUCH_POOL_EMPTY_TG=1

ZCT_PLAY03_TP_MODE=vwap

# VWAP 信号：严格 PA 默认开；recycled 结构位否决默认关

ZCT_STRICT_PA_FILTERS=1

ZCT_RECYCLED_NEAR_VETO_ENABLED=0

ZCT_RECYCLED_NEAR_MAX_DIST_PCT=0.2

ZCT_TOUCH_POOL_TAKER_BPS=4

ZCT_TOUCH_POOL_SLIPPAGE_BPS=1.5



# 值得关注七类 worth_watch_* 归档保留（含当日共 N 个日历日，默认 7）

# WORTH_WATCH_RETENTION_DAYS=7

# WORTH_HOT_OI_RETENTION_DAYS=7



# 数据目录（Railway 挂载 Volume 时通常为 /data）

# DATA_DIR=/data



# 维护：清库 / 手动 Cron（生产建议设置）

# NEXT_K_MAINTENANCE_TOKEN=your-secret



# 临时导出 Railway Volume（DATA_DIR）为 zip；下载后务必关掉并重新部署

# NEXT_K_EXPORT_VOLUME_ENABLED=1

# 浏览器: GET /export-volume?maintenance_token=YOUR_TOKEN

# 维护面板亦可一键导出；打包前可看 GET /api/export-volume/info



# 可选

# S6_FUTURES_ALPHA_SCHEDULER_ENABLED=1

# OI_RADAR_REFRESH_COOLDOWN_SEC=120

ZCT_VWAP_SCAN_INTERVAL_MINUTES=7

# ZCT_VWAP_RESOLVE_INTERVAL_MINUTES=5



# ── Next K Protocol 对接（信号推送至独立实盘服务）─────────────────────────────

# PROTOCOL_API_URL=http://localhost:8001   # Next-k-protocol 服务地址

# PROTOCOL_MAINTENANCE_TOKEN=your-token    # 与 Next-k-protocol 一致的鉴权 token



# 未触 SL/TP 最长持仓：全局 4h；PLAY01=5h / PLAY02=4h / PLAY03=3h（小时或毫秒，0=回退全局）

# ZCT_RESOLVE_MAX_HOLD_MS=14400000

# ZCT_RESOLVE_MAX_BARS=240

# ZCT_RESOLVE_MAX_HOLD_HOURS_PLAY01=5

# ZCT_RESOLVE_MAX_HOLD_HOURS_PLAY02=4

# ZCT_RESOLVE_MAX_HOLD_HOURS_PLAY03=3

