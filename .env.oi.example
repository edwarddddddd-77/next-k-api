# Next K API — 本地 / Railway 环境变量示例
# 复制为 next-k-api/.env.oi

NEXT_K_EMBED_SCHEDULER=1

# DATA_DIR=/data
# NEXT_K_EXPORT_VOLUME_ENABLED=1

# ORB 盘前过滤 — 推荐 production（Alpaca 盘前 + Binance RTH）
ORB_PREMARKET_FILTER=1
ORB_PREMARKET_SOURCE=alpaca
ORB_PREMARKET_MODE=enhanced
ORB_PREMARKET_RVOL_MIN=0
ORB_PREMARKET_MIN_VOLUME=0
ORB_PREMARKET_REQUIRE_PMH_LONG=1
ORB_PREMARKET_REQUIRE_PML_SHORT=1
ORB_PREMARKET_REQUIRE_VWAP_LONG=1
ORB_PREMARKET_REQUIRE_VWAP_SHORT=1
ORB_PREMARKET_PMH_BUFFER_BPS=10
# ALPACA_API_KEY=your-key
# ALPACA_API_SECRET=your-secret
# ALPACA_DATA_FEED=iex
# 有 SIP 订阅时: ALPACA_DATA_FEED=sip
# ORB_SCAN_INTERVAL_MINUTES=5
# ORB_SCAN_CRON_SECOND=5

# ORB 每标 bot 初始本金（U）
# ORB_SYMBOL_BOT_EQUITY=1000

# ORB 实盘 → Next-k-protocol（Railway 设 ORB_LIVE_ENABLED=1 开启，=0 关闭）
# ORB_LIVE_ENABLED=0
# PROTOCOL_API_URL=http://localhost:8001
# ORB_LIVE_LEVERAGE=5
# ORB_LEVERAGE=5
# ORB_MARGIN_USDT=100

# 大户多空雷达
TOP_TRADER_UNIVERSE=trend_5m
TOP_TRADER_PERIOD=15m
TOP_TRADER_POOL_MAX=0
# TOP_TRADER_SCHEDULER_ENABLED=0
TOP_TRADER_CRON_MINUTE=45
