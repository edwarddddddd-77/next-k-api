# Next K API — Trading ORB vnpy 实盘（币安直连）
# 复制为 next-k-api/.env.oi

NEXT_K_EMBED_SCHEDULER=1

# ═══════════════════════════════════════════════════════════════
# Trading ORB（sam-bateman/trading-orb 规则 + vnpy + 币安）
# ═══════════════════════════════════════════════════════════════
ORB_VNPY_ENABLED=1
ORB_VNPY_AUTO_START=1
ORB_VNPY_LIVE_ENABLED=1
# 币安 API
BINANCE_API_KEY=
BINANCE_API_SECRET=
# BINANCE_SERVER=REAL
# BINANCE_KLINE_STREAM=True
# BINANCE_PROXY_HOST=
# BINANCE_PROXY_PORT=0

# Bybit 实盘（VNPY_LIVE_EXCHANGE=bybit 时使用）
# VNPY_LIVE_EXCHANGE=binance
# 行情源（默认同 VNPY_LIVE_EXCHANGE，可单独指定）
# MARKET_DATA_EXCHANGE=binance
# BYBIT_API_KEY=
# BYBIT_API_SECRET=
# BYBIT_SERVER=REAL
# BYBIT_PROXY_HOST=
# BYBIT_PROXY_PORT=0

# 标的池 config/trading_orb/symbols.txt
# ORB_VNPY_SYMBOLS=INTCUSDT,SOXLUSDT,HOODUSDT

ORB_MARKET=us_equity
ORB_SESSION_TZ=America/New_York
ORB_SESSION_OPEN=09:30
ORB_SESSION_CLOSE=16:00
ORB_MACRO_FILTER=1

# trading-orb 核心参数（ORB_VNPY_* 与 ORB V2 扫描隔离）
ORB_VNPY_OR_MINUTES=20
ORB_VNPY_VOL_THRESH=1.2
ORB_VNPY_STOP_OR_MULT=0.5
ORB_VNPY_TARGET_OR_MULT=0.75
ORB_VNPY_BREAKEVEN_OR_MULT=1.0
ORB_VNPY_ENTRY_START=10:00
ORB_VNPY_ENTRY_END=11:30
ORB_VNPY_EXIT_HOUR=15
ORB_VNPY_EXIT_MINUTE=50

ORB_VNPY_EQUITY_USDT=98
ORB_VNPY_RISK_PCT=0.01
# 固定美元风险（>0 时覆盖 risk_pct）
# ORB_VNPY_RISK_PER_TRADE=400
ORB_VNPY_MAX_OPEN_POSITIONS=7
ORB_VNPY_LIVE_LEVERAGE=5
ORB_ONE_TRADE_PER_SESSION=1

# ORB_VNPY_SHADOW=1
# ORB_VNPY_IDLE_OUTSIDE_RTH=1