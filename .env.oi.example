# Hyperliquid short desk (hl-short): in-process proportional paper mirror
# One bot per watchlist address; open/increase/reduce/close/flip all followed.
# HL_COPY_ENABLED=1
# HL_PAPER_BALANCE=1000
# Per-bot override (also via watchlist paper_balance): HL_PAPER_BALANCE_BOT_A=2000
# HL_MIN_NOTIONAL=10
# HL_LEVERAGE_ADJUSTMENT=1.0
# HL_DAILY_LOSS_PCT=0.20
# Flag target wallet empty / quiet (UI + logs)
# HL_TARGET_EMPTY_AV=100
# HL_TARGET_INACTIVE_HOURS=8
# HL_TARGET_HEALTH_SEC=300
# HL_SHORT_REFRESH_COOLDOWN_SEC=20
# HL_PAPER_MARK_COOLDOWN_SEC=45
# HL_MIDS_CACHE_SEC=30
# HL_PAPER_MARK_LOOP_SEC=60
# HL_WATCHLIST_RELOAD_SEC=120
#
# === HL → Bitget SUB-ACCOUNTS (Railway) ===
# Max 5 bots A–E. Secrets ONLY in Railway Variables — never in JSON.
# Routing: hl_bitget_subaccounts.json (id / bot_id / coins / env_prefix / enabled)
#
# Dry-run test (writes ledger, no real orders):
#   HL_BITGET_LIVE=1
#   HL_BITGET_DRY_RUN=1
# Live:
#   HL_BITGET_LIVE=1
#   HL_BITGET_DRY_RUN=0
#
# HL_BITGET_MODE=sub
# HL_BITGET_MAX_SUBACCOUNTS=8
# HL_BITGET_SCALE=1.0
# HL_BITGET_MIN_NOTIONAL=5
# Coalesce burst HL fills into one Bitget position sync (ms; 0 = immediate)
# HL_BITGET_DEBOUNCE_MS=1000
# HL_BITGET_VERIFY_SYMBOLS=1
#
# Enable bots (pick ≤5):
# HL_BITGET_SUB_A_ENABLED=1
# HL_BITGET_SUB_B_ENABLED=1
# HL_BITGET_SUB_C_ENABLED=1
# HL_BITGET_SUB_D_ENABLED=1
# HL_BITGET_SUB_E_ENABLED=1
#
# Per-bot API keys (Bitget sub-account):
# BITGET_SUB_A_API_KEY=
# BITGET_SUB_A_API_SECRET=
# BITGET_SUB_A_PASSPHRASE=
# BITGET_SUB_B_API_KEY=
# BITGET_SUB_B_API_SECRET=
# BITGET_SUB_B_PASSPHRASE=
# BITGET_SUB_C_API_KEY=
# BITGET_SUB_C_API_SECRET=
# BITGET_SUB_C_PASSPHRASE=
# BITGET_SUB_D_API_KEY=
# BITGET_SUB_D_API_SECRET=
# BITGET_SUB_D_PASSPHRASE=
# BITGET_SUB_E_API_KEY=
