# 复制为 next-k-api/.env.oi（本地）或写入 Railway 环境变量
# 单服务：API 进程内嵌定时任务，无需再跑 scheduler_main.py

NEXT_K_EMBED_SCHEDULER=1
ZCT_VWAP_SIGNAL_SCHEDULER_ENABLED=1

# 触轨池双引擎：08:05 全市场主筛 + 每 4h 池内 24h 滚动回测清洗
# ZCT_TOUCH_POOL_CRON_HOUR=8
# ZCT_TOUCH_POOL_CRON_MINUTE=5
# 滚动清洗（12:05/16:05/20:05/00:05/04:05）：池内 24h 回测；触轨胜率<70% / PF<1.15 / 末段连亏>=3 则出池
# ZCT_TOUCH_POOL_ROLLING_ENABLED=1
# ZCT_TOUCH_POOL_ROLLING_MIN_WIN_RATE=0.70
# ZCT_TOUCH_POOL_ROLLING_MIN_PF=1.15
# ZCT_TOUCH_POOL_ROLLING_MAX_CONSEC_LOSSES=3
# ZCT_TOUCH_POOL_ROLLING_MIN_TOUCH_TRADES=5
# ZCT_TOUCH_POOL_ROLLING_DAYS=1
# ZCT_TOUCH_POOL_EMPTY_TG=1
# ZCT_PLAY03_TP_MODE=vwap
# VWAP 信号：默认关严格 PA / recycled 结构位否决（贴近 Masterclass 海报；要开则设 1）
# ZCT_STRICT_PA_FILTERS=0
# ZCT_RECYCLED_NEAR_VETO_ENABLED=0
# ZCT_RECYCLED_NEAR_MAX_DIST_PCT=0.2
# ZCT_TOUCH_POOL_TAKER_BPS=4
# ZCT_TOUCH_POOL_SLIPPAGE_BPS=1.5

# 值得关注七类 worth_watch_* 归档保留（含当日共 N 个日历日，默认 7）
# WORTH_WATCH_RETENTION_DAYS=7
# WORTH_HOT_OI_RETENTION_DAYS=7

# 数据目录（Railway 挂载 Volume 时通常为 /data）
# DATA_DIR=/data

# 维护：清库 / 手动 Cron（生产建议设置）
# NEXT_K_MAINTENANCE_TOKEN=your-secret

# 可选
# S6_FUTURES_ALPHA_SCHEDULER_ENABLED=1
# OI_RADAR_REFRESH_COOLDOWN_SEC=120
# ZCT_VWAP_SCAN_INTERVAL_MINUTES=12
# ZCT_VWAP_RESOLVE_INTERVAL_MINUTES=5

# ── 币安实盘桥（可选，不设则模块不加载）─────────────────────────────────────
# BINANCE_ENABLED=1                       # 启用实盘桥；关闭则不加载任何 binance 代码
# BINANCE_API_KEY=your-api-key            # 币安 API Key（或启动后通过 /api/binance/config 写入 DB）
# BINANCE_API_SECRET=your-api-secret      # 币安 API Secret
# BINANCE_TESTNET=false                   # true = 使用 testnet.binancefuture.com
# BINANCE_MARGIN_USDT=100                # 单笔保证金（USDT），实际名义敞口 = 保证金 × 杠杆
# BINANCE_LEVERAGE=10                     # 杠杆倍数
# BINANCE_MAX_POSITIONS=3                 # 最大同时持仓数
# BINANCE_EXPIRE_HOURS=4                  # 持仓到期自动平仓时限（小时）

# 未触 SL/TP 最长持仓：全局 4h；PLAY01=5h / PLAY02=4h / PLAY03=3h（小时或毫秒，0=回退全局）
# ZCT_RESOLVE_MAX_HOLD_MS=14400000
# ZCT_RESOLVE_MAX_BARS=240
# ZCT_RESOLVE_MAX_HOLD_HOURS_PLAY01=5
# ZCT_RESOLVE_MAX_HOLD_HOURS_PLAY02=4
# ZCT_RESOLVE_MAX_HOLD_HOURS_PLAY03=3
