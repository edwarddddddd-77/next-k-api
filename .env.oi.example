# Next K API — Trading ORB vnpy 实盘（币安直连）
# 复制为 next-k-api/.env.oi

NEXT_K_EMBED_SCHEDULER=1

# ═══════════════════════════════════════════════════════════════
# Trading ORB（sam-bateman/trading-orb 规则 + vnpy + 币安）
# ═══════════════════════════════════════════════════════════════
ORB_VNPY_ENABLED=1
ORB_VNPY_AUTO_START=1
ORB_VNPY_LIVE_ENABLED=1
# 币安 API
BINANCE_API_KEY=
BINANCE_API_SECRET=
# BINANCE_SERVER=REAL
# BINANCE_KLINE_STREAM=True
# BINANCE_PROXY_HOST=
# BINANCE_PROXY_PORT=0

# Bitget 实盘（VNPY_LIVE_EXCHANGE=bitget 时使用，推荐）
# VNPY_LIVE_EXCHANGE=bitget
# MARKET_DATA_EXCHANGE=bitget
# BITGET_API_KEY=
# BITGET_API_SECRET=
# BITGET_PASSPHRASE=
# BITGET_SERVER=REAL
# BITGET_PROXY_HOST=
# BITGET_PROXY_PORT=0

# 兼容旧配置：bybit 会自动映射为 bitget

# 标的池 config/trading_orb/symbols.txt
# ORB_VNPY_SYMBOLS=INTCUSDT,SOXLUSDT,HOODUSDT

ORB_MARKET=us_equity
ORB_SESSION_TZ=America/New_York
ORB_SESSION_OPEN=09:30
ORB_SESSION_CLOSE=16:00
ORB_MACRO_FILTER=1

# trading-orb 核心参数（ORB_VNPY_* 与 ORB V2 扫描隔离）
ORB_VNPY_OR_MINUTES=20
ORB_VNPY_VOL_THRESH=1.2
ORB_VNPY_STOP_OR_MULT=0.5
ORB_VNPY_TARGET_OR_MULT=0.75
ORB_VNPY_BREAKEVEN_OR_MULT=1.0
ORB_VNPY_ENTRY_START=10:00
ORB_VNPY_ENTRY_END=11:30
ORB_VNPY_EXIT_HOUR=15
ORB_VNPY_EXIT_MINUTE=50

ORB_VNPY_EQUITY_USDT=98
ORB_VNPY_RISK_PCT=0.01
# 固定美元风险（>0 时覆盖 risk_pct）
# ORB_VNPY_RISK_PER_TRADE=400
ORB_VNPY_MAX_OPEN_POSITIONS=7
ORB_VNPY_LIVE_LEVERAGE=5
ORB_ONE_TRADE_PER_SESSION=1

# ORB_VNPY_SHADOW=1
# ORB_VNPY_IDLE_OUTSIDE_RTH=1

# ═══════════════════════════════════════════════════════════════
# IBS — 5m 聚合美东 RTH 日线（对齐 SPY/QQQ 正盘；勿用 Bitget 1D）
# 保守 SPY（Pagonidis）| 激进 TQQQ（CazSyd）| TV SPY+QQQ（AlgoTradeKit）
# 默认 Bitget 现货 tokenized ETF（更接近原版 SPY/TQQQ 现货）
# 保守与 TV 均含 SPY — 勿同时启用 ibs_conservative + ibs_tv
# ═══════════════════════════════════════════════════════════════
# VNPY_LIVE_EXCHANGE=bitget_spot
# MARKET_DATA_EXCHANGE=bitget_spot
# IBS_*_VNPY_PRODUCT_TYPE=spot   # spot（默认）| perp（永续 SPYUSDT/TQQQUSDT）
# 对齐原版：三条 IBS 均为 long_only（只做多）。TV 回测须设 Trade Type = Long only（勿用 Long+Short）
# 1/2 保守+激进：现货 bitget_spot；3 ibs_tv：永续 bitget + long_short（见下方 TV 段）
# 现货映射：SPY→SPYONUSDT  QQQ→QQQONUSDT  TQQQ→RTQQQUSDT
# config/ibs_*/symbols.txt 仍写 SPY / QQQ / TQQQ；spot 模式自动映射为 SPYON/QQQON/rTQQQ
# STRATEGY_IBS_CONSERVATIVE_ENABLED=1
# STRATEGY_IBS_AGGRESSIVE_ENABLED=1
# IBS_CONSERVATIVE_VNPY_EQUITY_USDT=100
# IBS_AGGRESSIVE_VNPY_EQUITY_USDT=100
# IBS_CONSERVATIVE_VNPY_POSITION_PCT=0.10
# IBS_AGGRESSIVE_VNPY_POSITION_PCT=0.30
# STRATEGY_IBS_CONSERVATIVE_LIVE=0
# STRATEGY_IBS_AGGRESSIVE_LIVE=0
# IBS TV（AlgoTradeKit v0.5）：永续 + Long+Short；按标的默认参数见 quant/ibs_tv/symbol_params.py
# SPY: entry 0.11 exit 0.995 EMA200 max_days 12 | QQQ: 0.09 0.985 EMA220 max_days 14
# STRATEGY_IBS_TV_ENABLED=1
# IBS_TV_VNPY_PRODUCT_TYPE=perp
# IBS_TV_VNPY_TRADE_TYPE=long_short
# VNPY_LIVE_EXCHANGE=bitget
# MARKET_DATA_EXCHANGE=bitget
# IBS_TV_VNPY_LIVE_LEVERAGE=5
# IBS_TV_VNPY_POSITION_PCT=1.0
# IBS_TV_VNPY_STOP_LOSS_PCT=0
# IBS_TV_VNPY_MIN_ENTRY_DISTANCE_PCT=0
# 以下 env 会覆盖按标的默认；不设则走 SPY/QQQ 各自推荐值
# IBS_TV_VNPY_ENTRY_THRESHOLD=
# IBS_TV_VNPY_EXIT_THRESHOLD=
# IBS_TV_VNPY_TREND_MA_PERIOD=
# IBS_TV_VNPY_MAX_TRADE_DURATION_DAYS=
# IBS_TV_VNPY_DAILY_BAR_SOURCE=session_5m
# IBS_TV_VNPY_EXECUTE_AT_NEXT_OPEN=1
# IBS_TV_VNPY_EXEC_AFTER_OPEN_MINUTES=1
# STRATEGY_IBS_TV_LIVE=0

# ═══════════════════════════════════════════════════════════════
# Breakout 双 lane（scanner watchlist 自动读取，无需额外配置）
# 定时任务: python run_scanner.py watchlist
# ═══════════════════════════════════════════════════════════════
# STRATEGY_SQUEEZE_BREAKOUT_ENABLED=1
# SQUEEZE_BREAKOUT_VNPY_SHADOW=1
# STRATEGY_BREAKOUT_DONCHIAN_ENABLED=1
# BREAKOUT_DONCHIAN_VNPY_SHADOW=1